SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Requerido para invite/register. Generar: openssl rand -hex 32
INVITE_SECRET=
# Requerido para fichajes (cadena hashes). Generar: openssl rand -hex 32
HASH_PEPPER=
RESET_PASSWORD_REDIRECT_URL=
# URL override para el link de bienvenida tras import (si no se configura, usa RESET_PASSWORD_REDIRECT_URL)
IMPORT_WELCOME_REDIRECT_URL=
# Proveedor de email para emails de bienvenida. Valores: resend | (vacío = deshabilitado)
EMAIL_PROVIDER=
# API Key de Resend (si EMAIL_PROVIDER=resend). Obtener en https://resend.com
RESEND_API_KEY=
# Nombre del remitente en emails (default: fichAR)
APP_NAME=
# Email del remitente (default: fichAR <noreply@fichar.app>)
EMAIL_FROM=
# Opcional. Para rate limiting distribuido (multi-instancia). Sin esto: in-memory (single instance).
# Crear DB en https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Orígenes permitidos para CORS. En producción usar whitelist explícita separada por coma.
# Ejemplo: https://app.fichar.com,https://admin.fichar.com
CORS_ORIGINS=
PORT=3000
