SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Requerido para invite/register. Generar: openssl rand -hex 32
INVITE_SECRET=
# Requerido para fichajes (cadena hashes). Generar: openssl rand -hex 32
HASH_PEPPER=
# URL de redireccion tras reset de password: management (Next.js). Usado cuando el reset se pide desde fichar-management o sin redirect_to.
# Produccion management: https://management.tudominio.com/set-password
RESET_PASSWORD_REDIRECT_URL=
# URL de redireccion para empleados (fichar-app Flutter web). Usado cuando el reset se pide desde la app con redirect_to=app.
# Produccion Flutter Web: https://web-fichar.vercel.app (sin barra final; Supabase anade #access_token=...)
RESET_PASSWORD_REDIRECT_URL_APP=
# URL override para el link de bienvenida tras import (si no se configura, usa RESET_PASSWORD_REDIRECT_URL)
IMPORT_WELCOME_REDIRECT_URL=
# Proveedor de email: gmail | sendgrid | resend
EMAIL_PROVIDER=
# Si TRUE: no se envia via SendGrid (ahorra costos). Solo aplica cuando EMAIL_PROVIDER=sendgrid.
EMAIL_SENDGRID_DISABLED=
# Gmail (pruebas): SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER= SMTP_PASS= (App Password)
# SendGrid (prod): SENDGRID_API_KEY=SG.xxx. Ver documentation/tecnica/sendgrid-setup.md
# Resend: RESEND_API_KEY=re_xxx
RESEND_API_KEY=
# Gmail SMTP (si EMAIL_PROVIDER=gmail). fichAR-management: ficharmanagement@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ficharmanagement@gmail.com
SMTP_PASS=
# SendGrid (si EMAIL_PROVIDER=sendgrid). Crear en https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# Categorias SendGrid para tracking/campana (comma-separated, max 10). Ej: fichar-test-2302
EMAIL_SENDGRID_CATEGORIES=
# Nombre del remitente en emails (default: fichAR)
APP_NAME=
# Email del remitente (ej: fichAR Management <ficharmanagement@gmail.com>)
EMAIL_FROM=
# Opcional. Para rate limiting distribuido (multi-instancia). Sin esto: in-memory (single instance).
# Crear DB en https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Management API key (fichar-management). Requerido para POST /management/organizations.
# Generar: openssl rand -hex 32
MANAGEMENT_API_KEY=
# Set to "true" only if self-registration must be allowed (legacy). Default: disabled.
REGISTER_ORG_ENABLED=
# Orígenes permitidos para CORS. Separados por coma. Requerido en producción (si vacío, no se permite ningún origen).
# Desarrollo: http://localhost:3001 (management)
# Producción: https://app.fichar.com,https://management.fichar.com
CORS_ORIGINS=
PORT=3000
