SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Requerido para invite/register. Generar: openssl rand -hex 32
INVITE_SECRET=
# Requerido para fichajes (cadena hashes). Generar: openssl rand -hex 32
HASH_PEPPER=
RESET_PASSWORD_REDIRECT_URL=
# Opcional. Para rate limiting distribuido (multi-instancia). Sin esto: in-memory (single instance).
# Crear DB en https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Orígenes permitidos para CORS. En producción usar whitelist explícita separada por coma.
# Ejemplo: https://app.fichar.com,https://admin.fichar.com
CORS_ORIGINS=
PORT=3000
